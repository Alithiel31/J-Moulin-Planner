{
  "name": "jmoulin-api",
  "version": "1.0.0",
  "description": "API REST pour Planificateur J.Moulin",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:push": "node --env-file=.env node_modules/prisma/build/index.js db push",
    "db:migrate": "node --env-file=.env node_modules/prisma/build/index.js migrate deploy",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:seed:docker": "tsx --env-file=.env.docker prisma/seed.ts",
    "db:reset": "node --env-file=.env node_modules/prisma/build/index.js db push --force-reset && npm run db:seed",
    "db:studio": "node --env-file=.env node_modules/prisma/build/index.js studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "node --test --env-file=.env ./src/**/*.spec.test.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.svelte": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-xss-sanitizer": "^2.0.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@types/pg": "^8.11.10",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7"
  }
}